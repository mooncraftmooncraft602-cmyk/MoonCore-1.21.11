{
  "schemaVersion": 1,
  "id": "mooncore-companion",
  "version": "${version}",
  "name": "MoonCore Companion",
  "description": "Mod client optionnel pour les serveurs MoonCore : studio, modeles et animations avances cote Java. Le serveur fonctionne sans lui.",
  "authors": ["MoonCore"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": ["com.mooncore.companion.MoonCoreCompanionClient"]
  },
  "mixins": [
    "mooncore-companion.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16",
    "minecraft": "${supported_minecraft_versions}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
